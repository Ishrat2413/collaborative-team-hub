# ─── Database ────────────────────────────────────────────────────────────────
# Local: postgresql://USER:PASSWORD@localhost:5432/team_hub
# Railway: Automatically injected — do not set manually on Railway
DATABASE_URL="postgresql://team_hub_user:yourpassword@localhost:5432/team_hub"

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Generate strong random secrets: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET="change-me-to-a-long-random-string-min-32-chars"
JWT_REFRESH_SECRET="change-me-to-another-long-random-string-min-32-chars"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ─── Cloudinary ───────────────────────────────────────────────────────────────
# Get these from https://console.cloudinary.com/
CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"

# ─── App ─────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# URL of your frontend (used for CORS)
# Local: http://localhost:3000
# Production: https://your-web.up.railway.app
CLIENT_URL="http://localhost:3000"
